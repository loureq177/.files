{
  "layer": "top",
  "height": 25,
  "spacing": 4,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],

  "modules-center": ["clock"],

  "modules-right": [
    "privacy",
    "custom/caffeine",
    "pulseaudio",
    "pulseaudio#microphone",
    "bluetooth",
    "custom/clipboard",
    "cpu",
    "memory",
    "battery",
    "network",
    "custom/power",
  ],

  "privacy": {
    "icon-spacing": 4,
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24,
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 24,
      },
    ],
  },

  "custom/caffeine": {
    "format": "{}",
    "interval": 2,
    "exec": "pidof hypridle > /dev/null && echo 'ًں’¤' || echo 'âک•'",
    "on-click": "pidof hypridle > /dev/null && pkill hypridle || hypridle &",
    "tooltip": false,
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°–پ {volume}%",
    "format-icons": {
      "headphone": "ï€¥",
      "hands-free": "ï–گ",
      "headset": "ï–گ",
      "phone": "ï‚•",
      "portable": "ï‚•",
      "car": "ï†¹",
      "default": ["ï€¦", "ï€§", "ï€¨"],
    },
    "on-click": "pwvucontrol --tab 4",
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "ï„°",
    "format-source-muted": "ï„±",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-click-right": "pwvucontrol --tab 3",
  },

  "bluetooth": {
    "format": "ïٹ”",
    "format-connected": "ïٹ” {num_connections}",
    "format-connected-battery": "ïٹ” {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "ghostty --title=bluetui-float -e bluetui",
  },

  "custom/clipboard": {
    "format": "َ°…Œ",
    "on-click": "~/.config/hypr/scripts/cliphist-paste.sh",
    "tooltip": false,
  },

  "network": {
    "format-wifi": "ï‡«",
    "format-ethernet": "َ°ˆ€",
    "format-disconnected": "َ°–ھ",
    "tooltip-format": "{essid}\nIP: {ipaddr}\nSignal: {signalStrength}%",
    "on-click": "ghostty --title=impala-float -e impala",
  },

  "custom/power": {
    "format": "âڈ»",
    "on-click": "~/.config/hypr/scripts/powermenu.sh",
    "tooltip": false,
  },

  "hyprland/window": {
    "format": "{title}",
    "max-length": 50,
    "tooltip": true,
    "tooltip-format": "{title}",
    "separate-outputs": true,
    "on-click": "hyprctl activewindow -j | jq -r '.title' | wl-copy",
  },

  "hyprland/workspaces": {
    "format": "{icon}",
  },

  "cpu": {
    "interval": 5,
    "format": "ï’¼â€¯{usage}%",
    "on-click": "ghostty --title=btop-float -e btop",
    "tooltip": true,
    "tooltip-format": "Load: {load_percent:.1f}%\nFreq: {frequency} MHz",
  },

  "memory": {
    "interval": 5,
    "format": "َ°چ›â€¯{}%",
    "on-click": "ghostty --title=btop-float -e btop",
    "tooltip": true,
    "tooltip-format": "Used: {used}/{total}\nAvail: {avail}",
  },

  "battery": {
    "interval": 60,
    "format": "{icon} {capacity}%",
    "format-charging": "ï‡¦ {capacity}%",
    "format-plugged": "ï‡¦ {capacity}%",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    "tooltip": true,
    "tooltip-format": "{capacity}%\nRemaining time: {time}",
  },

  "clock": {
    "interval": 60,
    "format": "{:%d %B %Y, %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
  },
}
