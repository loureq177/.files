#!/usr/bin/env zsh

local orphans
orphans=$(paru -Qdtq)


if [ -n "$orphans" ]; then
    echo "Orphaned packages to be deleted:\n$orphans" | xargs paru -Rns --noconfirm
fi

echo "Cleaning cached packages..."
paru -Scc --noconfirm

echo "\nCleaning pacman cache..."
sudo rm -rf /var/cache/pacman/pkg/*

echo "\nCleaning ~/.cache older than 30 days..."
find "$HOME/.cache" -type f -atime +30 -delete 2>/dev/null || true
echo "\nYour system is clean."
