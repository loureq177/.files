{
  "layer": "top",
  "height": 25,
  "spacing": 2,
  "margin-top": 4,
  "margin-left": 6,
  "margin-right": 6,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],

  "modules-center": ["clock", "custom/notification"],

  "modules-right": [
    "custom/record",
    "privacy",
    "custom/caffeine",
    "custom/theme",
    "custom/dictate",
    "pulseaudio",
    "memory",
    "temperature",
    "bluetooth",
    "network",
    "battery",
  ],

  "privacy": {
    "icon-spacing": 4,
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24,
      },

    ],
  },

  // signal 2 â€” dodaj pkill -RTMIN+2 waybar do record-toggle.sh przy start/stop
  "custom/record": {
    "exec": "~/.config/waybar/scripts/record-status.sh",
    "return-type": "json",
    "interval": "once",
    "signal": 2,
  },

  // signal 1 â€” caffeine-toggle.sh juإ¼ wysyإ‚a RTMIN+1
  "custom/caffeine": {
    "exec": "~/.config/hypr/scripts/caffeine-toggle.sh --status",
    "on-click": "~/.config/hypr/scripts/caffeine-toggle.sh",
    "return-type": "json",
    "interval": "once",
    "signal": 1,
  },

  "custom/theme": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/theme-status.sh",
    "on-click": "hyprctl dispatch 'hl.dsp.exec_cmd(\"~/.config/hypr/scripts/theme-toggle.sh\")'",
    "return-type": "json",
    "signal": 10,
  },

  // signal 8 â€” dictate.sh / mute toggle
  "custom/dictate": {
    "exec": "~/.config/waybar/scripts/dictate-status.sh",
    "return-type": "json",
    "interval": "once",
    "signal": 8,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle && pkill -RTMIN+8 waybar",
    "on-click-right": "pwvucontrol --tab 3",
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°–پ {volume}%",
    "format-icons": {
      "headphone": "",
      "hands-free": "",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"],
    },
    "on-click": "pwvucontrol --tab 4",
  },

  "bluetooth": {
    "format": "ïٹ”",
    "format-connected": "ïٹ” {num_connections}",
    "format-connected-battery": "ïٹ” {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "hyprctl dispatch \"hl.dsp.workspace.toggle_special('bluetui')\"",
  },

  "network": {
    "format-wifi": "َ°–©",
    "format-ethernet": "َ°ˆ€",
    "format-disconnected": "َ°–ھ",
    "tooltip-format": "{essid}\nIP: {ipaddr}\nSignal: {signalStrength}%",
    "on-click": "hyprctl dispatch \"hl.dsp.workspace.toggle_special('impala')\"",
  },

  "hyprland/window": {
    "format": "{title}",
    "max-length": 30,
    "tooltip": true,
    "tooltip-format": "{title}",
    "separate-outputs": true,
    "on-click": "hyprctl activewindow -j | jq -r '.title' | wl-copy",
  },

  "hyprland/workspaces": {
    "format": "{name}",
  },

  "memory": {
    "interval": 5,
    "format": "َ°چ› {}%",
    "on-click": "hyprctl dispatch \"hl.dsp.workspace.toggle_special('btop')\"",
    "tooltip": true,
    "tooltip-format": "Used: {used}/{total}\nAvail: {avail}",
  },

  "temperature": {
    "hwmon-path-abs": "/sys/class/hwmon/hwmon4/temp1_input",
    "interval": 5,
    "format": "{icon} {temperatureC}آ°C",
    "format-icons": ["ï‹‹", "ï‹‰", "ï‹‡"],
    "critical-threshold": 85,
    "tooltip": true,
  },

  "battery": {
    "interval": 60,
    "format": "{icon} {capacity}%",
    "format-charging": "{icon} {capacity}%",
    "format-plugged": "{icon} {capacity}%",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    "tooltip": true,
    "tooltip-format": "{capacity}%\nRemaining time: {time}",
    "states": {
      "warning": 20,
      "critical": 10,
    },
  },

  "clock": {
    "interval": 60,
    "format": "{:%d %B %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
  },

  "custom/notification": {
    "format": "{icon}",
    "format-icons": {
      "notification": "َ°‚ڑ",
      "dnd-notification": "َ°‚›",
      "dnd-none": "َ°‚›",
    },
    "return-type": "json",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  },
}
