#!/bin/bash

set -euo pipefail

DIR="$(dirname "$(realpath "$0")")"
PACKAGE_DIR="$(cd "$DIR/../.." && pwd)"

echo "Setting up Dictate (Speech-to-Text) for Hyprland..."

python -m venv "$PACKAGE_DIR/.venv"
source "$PACKAGE_DIR/.venv/bin/activate"
pip install --upgrade pip
pip install faster-whisper nvidia-cublas-cu12 nvidia-cudnn-cu12

KEYBIND_LINE='hl.bind("SUPER + CTRL + S", hl.dsp.exec_cmd("~/.local/bin/dictate.sh"))'

KEYBINDINGS_FILE="$HOME/.config/hypr/conf/keybindings.lua"

if [ -f "$KEYBINDINGS_FILE" ]; then
    if ! grep -q "dictate.sh" "$KEYBINDINGS_FILE"; then
        echo "" >> "$KEYBINDINGS_FILE"
        echo "-- Speech-to-Text (Dictate)" >> "$KEYBINDINGS_FILE"
        echo "$KEYBIND_LINE" >> "$KEYBINDINGS_FILE"
        echo "Added keybinding to $KEYBINDINGS_FILE"
    else
        echo "Keybinding already exists in $KEYBINDINGS_FILE"
    fi
else
    echo "Warning: $KEYBINDINGS_FILE not found. Add manually:"
    echo "  $KEYBIND_LINE"
fi

echo ""
echo "Setup complete!"
echo "  - Venv: $PACKAGE_DIR/.venv"
echo "  - Scripts: ~/.local/bin/{dictate.sh,dictate_daemon.py}"
echo "  - Key: SUPER + CTRL + S (start/stop toggle)"
echo "  - Model: base (DICTATE_MODEL=tiny|small|medium)"
echo "  - Device: auto (AC→CUDA, battery→CPU)"
echo "  - Systemd: dictate-daemon.service enabled at login"
echo ""
echo "Run 'hyprctl reload' to activate keybinding."
echo "Systemd service pre-loads the model at login."
echo "Press SUPER+CTRL+S to toggle recording."
