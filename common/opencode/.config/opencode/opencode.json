{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "test every command by using tool call before adding it to file"
  ],
  "formatter": true,
  "lsp": true,
  "compaction": {
    "auto": true
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "lsp": "allow",
    "question": "allow",
    "task": "allow",
    "edit": "ask",
    "skill": "allow",
    "external_directory": {
      "~/**": "ask"
    },
    "bash": {
      "*": "ask",
      "git *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "paru -q *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "bat *": "allow",
      "tree *": "allow",
      "which *": "allow",
      "type *": "allow",
      "man *": "allow",
      "systemctl status *": "allow",
      "journalctl *": "allow",
      "file *": "allow"
    }
  }
}
