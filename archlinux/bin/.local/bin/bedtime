#!/usr/bin/env bash
set -euo pipefail

notify-send -t 5000 -u critical "Bedtime" -i "weather-night" "WiFi will turn off in 15 minutes."
sleep 600
notify-send -t 5000 -u critical "Bedtime" -i "weather-night" "WiFi will turn off in 5 minutes."
sleep 300
notify-send -t 5000 -u critical "Bedtime" -i "weather-night" "WiFi has been turned off."
nmcli radio wifi off
