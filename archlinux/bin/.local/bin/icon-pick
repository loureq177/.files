#!/usr/bin/env bash
set -euo pipefail

THEME="${1:-Papirus}"
SIZE="${2:-48x48}"
QUERY="${3:-}"

BASE="/usr/share/icons/$THEME/$SIZE"

if [[ ! -d "$BASE" ]]; then
    echo "Theme $THEME or size $SIZE not found at $BASE" >&2
    echo "Usage: icon-pick [theme] [size] [query]" >&2
    exit 1
fi

categories=(apps actions devices emotes mimetypes places status)

output() {
    local icon="$1"
    [[ -z "$icon" ]] && return
    echo "$icon"
    echo -n "$icon" | wl-copy
    echo "Copied to clipboard"
}

pick_category() {
    printf '%s\n' "${categories[@]}" |
        fzf --prompt="Pick a category: " \
            --preview="n=\$(find '$BASE/{}' -name '*.svg' 2>/dev/null | wc -l); echo '{}: \$n icons'" \
            --preview-window=up:2:wrap
}

pick_icon() {
    local cat="$1"
    local dir="$BASE/$cat"
    [[ ! -d "$dir" ]] && return 1

    find "$dir" -name "*.svg" -printf '%P\n' |
        sed 's/\.svg$//' |
        sort |
        fzf --preview="chafa --symbols solid --size 4x4 '$dir/{}.svg' 2>/dev/null" \
            --preview-window=left:8:wrap \
            --prompt="Pick an icon ($cat): "
}

search_all() {
    local tmp
    tmp=$(mktemp)
    for cat in "${categories[@]}"; do
        local dir="$BASE/$cat"
        [[ -d "$dir" ]] || continue
        find "$dir" -name "*.svg" -printf "$cat/%P\n"
    done | sed 's/\.svg$//' | sort >"$tmp"

    local result
    result=$(fzf --preview="chafa --symbols solid --size 4x4 '$BASE/{}.svg' 2>/dev/null" \
        --preview-window=left:8:wrap \
        --prompt="Search icons: " \
        --query="$QUERY" <"$tmp")
    rm -f "$tmp"
    echo "$result" | sed 's|^[^/]*/||'
}

if [[ -n "$QUERY" ]]; then
    icon=$(search_all)
    output "$icon"
else
    cat=$(pick_category)
    [[ -z "$cat" ]] && exit 0
    icon=$(pick_icon "$cat")
    output "$icon"
fi
