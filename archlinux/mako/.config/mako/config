font=Adwaita Sans 13
width=500
height=150
max-icon-size=70
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#89b4fa
progress-color=over #89b4fa
border-size=2
border-radius=12
padding=12
margin=8
default-timeout=0
ignore-timeout=true

max-visible=5
max-history=50

icon-location=left

group-by=app-name

on-button-left=invoke-default-action
on-button-right=dismiss
on-notify=exec pw-play /usr/share/sounds/freedesktop/stereo/message.oga
