#!/usr/bin/env bash
set -euo pipefail
mkdir -p "$HOME/.config/matlab" "$HOME/.local/share/matlab"
xhost +local: >/dev/null
podman run -it --rm \
    --privileged \
    --name matlab \
    --net=host \
    --userns=keep-id:uid=$(id -u),gid=$(id -g) \
    -e DISPLAY=$DISPLAY \
    -e QT_X11_NO_MITSHM=1 \
    -e NVIDIA_VISIBLE_DEVICES=all \
    -e NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics \
    -v /tmp/.X11-unix:/tmp/.X11-unix:ro \
    -v "$HOME/.local/share/matlab:/home/matlab/Documents/MATLAB" \
    -v "$HOME/.config/matlab:/home/matlab/.matlab" \
    --device nvidia.com/gpu=all \
    localhost/matlab:latest
