custom-shader = ~/.config/ghostty/shaders/cursor_warp.glsl
custom-shader-animation = always
theme = "TokyoNight Moon"
font-family = JetBrainsMono Nerd Font Mono
font-size = 14
cursor-style = block
cursor-style-blink = false
adjust-cell-height = 5%
mouse-hide-while-typing = true
confirm-close-surface = true
clipboard-read = allow
clipboard-write = allow
font-feature = -calt
gtk-titlebar = false
maximize = true

keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right

keybind = alt+shift+h=resize_split:left,10
keybind = alt+shift+j=resize_split:down,10
keybind = alt+shift+k=resize_split:up,10
keybind = alt+shift+l=resize_split:right,10

keybind = alt+d=scroll_page_lines:2
keybind = alt+u=scroll_page_lines:-2
