{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "You have access to the gtasks-cli command-line tool. You can use it to manage Google Tasks (add, list, complete tasks) directly through the bash tool without installing additional plugins."
  ],
  "formatter": true,
  "compaction": {
    "auto": true
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "ask",
    "todowrite": "allow",
    "webfetch": "allow",
    "lsp": "allow",
    "task": "allow",
    "skill": "ask",
    "question": "allow",
    "bash": {
      "gtasks*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "ls*": "allow",
      "pwd": "allow",
      "echo*": "allow",
      "find*": "allow",
      "grep*": "allow",
      "cat*": "allow",
      "paru -q*": "allow",
      "pacman -q*": "allow",
      "rg*": "allow",
      "fd*": "allow",
      "bat*": "allow",
      "tree*": "allow",
      "which*": "allow",
      "type*": "allow",
      "*": "ask"
    }
  }
}
