#!/usr/bin/env bash
set -euo pipefail

LOCKFILE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/rclone-sync.lock"
exec 200>"$LOCKFILE"
if ! flock -n 200; then
    echo "Another rclone sync is already running. Exiting."
    exit 0
fi

source_root="$HOME"
remote_root="google-drive-backup:mlorenc-backup"

excludes=(
    "--exclude=.*/**"
    "--exclude=.*"
    "--exclude=node_modules/**"
    "--exclude=.venv/**"
    "--exclude=venv/**"
    "--exclude=__pycache__/**"
    "--exclude=dist/**"
    "--exclude=build/**"
    "--exclude=target/**"
    "--exclude=.next/**"
    "--exclude=.idea/**"
    "--exclude=.vscode/**"
)

echo "Syncing: $source_root -> $remote_root"
if ! rclone sync \
    "$source_root" \
    "$remote_root" \
    "${excludes[@]}" \
    --progress \
    --drive-chunk-size 128M \
    --transfers 8 \
    --checkers 8 \
    --buffer-size 32M \
    --fast-list \
    --track-renames \
    --drive-use-trash=true \
    --verbose; then
    rc=$?
    notify-send --app-name "Rclone" -t 5000 "Rclone" -i "dialog-error" "Rclone Sync failed. Check the logs for details"
    exit "$rc"
fi
