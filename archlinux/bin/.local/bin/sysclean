#!/usr/bin/env zsh
set -euo pipefail

get_space() {
    df -m / "$HOME" | awk '!/Filesystem/ {sum+=$3} END {print sum}'
}

used_before=$(get_space)

echo "Cleaning orphaned packages..."
orphans=$(paru -Qdtq || true)
if [ -n "$orphans" ]; then
    paru -Rns --noconfirm ${=orphans}
else
    echo "There are no orphaned packages."
fi

echo "\nCleaning cached packages..."
paru -Scc --noconfirm

echo "\nCleaning Flatpak leftovers..."
flatpak uninstall --unused --noninteractive

echo "\nCleaning ~/.cache older than 30 days..."
find "$HOME/.cache" -type f -mtime +30 -delete 2>/dev/null || true

echo "\nVacuuming journal..."
sudo journalctl --vacuum-time=2weeks --quiet

freed=$(( used_before - $(get_space) ))

echo "\nYour system is clean."
if [ "$freed" -gt 0 ]; then
    echo "Successfully freed $freed MB of disk space."
fi
