#!/bin/bash

xhost +local:

podman run -d --rm \
    --name matlab \
    --net=host \
    --ipc=host \
    -e DISPLAY=$DISPLAY \
    -e QT_X11_NO_MITSHM=1 \
    -v /tmp/.X11-unix:/tmp/.X11-unix:ro \
    -v "$HOME/.local/share/matlab:/home/matlab/Documents/MATLAB" \
    -v "$HOME/.config/matlab:/home/matlab/.matlab" \
    --userns=keep-id \
    --device nvidia.com/gpu=all \
    docker.io/mathworks/matlab:latest
