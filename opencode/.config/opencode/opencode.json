{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "bash": {
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "ls*": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "paru -Q*": "allow",
      "pacman -Q*": "allow",
      "*": "ask"
    }
  }
}
