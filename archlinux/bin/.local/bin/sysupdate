#!/usr/bin/env zsh
set -euo pipefail

export PATH="$HOME/.bun/bin:$PATH"

paru -Syu --devel

if command -v nvim >/dev/null 2>&1; then
    nvim --headless "+Lazy! sync" \
        "+lua require('mason-registry').refresh(function() local P=require('mason-registry').get_installed_package_names(); if #P>0 then vim.cmd('MasonInstall '..table.concat(P,' ')) end; vim.cmd('qa') end)"
fi

if command -v bun >/dev/null 2>&1; then
    echo "\n"
    bun upgrade || true
fi

if command -v rustup >/dev/null 2>&1; then
    rustup update || true
fi

zsh -ic "zinit update --all && zinit self-update" || true

fwupdmgr refresh || true
fwupdmgr update -y || true

tldr --update || true

flatpak update --noninteractive
